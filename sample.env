# ==========================================
# TaskFlow Environment Variables Configuration
# ==========================================

# --- DATABASE SETTINGS ---
# Use standard JDBC connection settings for PostgreSQL (Neon/Local)
DATABASE_URL=jdbc:postgresql://<neon-hostname>/taskflow?sslmode=require
DATABASE_USER=postgres
DATABASE_PASSWORD=your_database_password

# --- JWT AUTHENTICATION SETTINGS ---
# Generate a secure 512-bit hex key for JWT token signing.
# Example generated with: openssl rand -hex 64
JWT_SECRET=your_jwt_signing_secret_here

# --- GEMINI AI SETTINGS ---
# Retrieve your API Key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# --- HUGGING FACE SETTINGS ---
# Optional Hugging Face API key, URL, and model configurations
HF_API_KEY=your_hf_api_key_here
HF_API_URL=https://router.huggingface.co/v1/chat/completions
HF_MODEL=meta-llama/Llama-3.3-70B-Instruct

# --- FRONTEND SETTINGS (React + Vite) ---
# Endpoint mapping for Axios client requests to the Spring Boot REST API
VITE_API_URL=http://localhost:8080/api
